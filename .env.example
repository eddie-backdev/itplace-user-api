# Spring profile
SPRING_PROFILES_ACTIVE=local

# PostgreSQL
PG_URL=jdbc:postgresql://localhost:5432/itplace
PG_USERNAME=postgres
PG_PASSWORD=
PG_REPLICA_URL=${PG_URL}
PG_REPLICA_USERNAME=${PG_USERNAME}
PG_REPLICA_PASSWORD=${PG_PASSWORD}

# Flyway
# 기존 DB의 최초 도입이 끝난 환경은 FLYWAY_BASELINE_ON_MIGRATE=false로 전환합니다.
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=20260722.0

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB
MONGODB_URI=mongodb://root:%21Password1127@localhost:27017/itplace?authSource=admin

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_SECONDS=3600
JWT_REFRESH_TOKEN_SECONDS=86400

# OpenAI
OPENAI_API_KEY=
OPENAI_ORGANIZATION_ID=
OPENAI_CHAT_MODEL=gpt-5-nano
SPRING_AI_OPENAI_CHAT_MODEL=gpt-5-nano

# Kakao OAuth
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Kakao Local API (server-side reverse geocoding)
KAKAO_REST_API_KEY=
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com

# Mail
MAIL_USERNAME=
MAIL_PASSWORD=

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
# Leave both empty when local Elasticsearch has security disabled.
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# CoolSMS
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_FROM_PHONE=

# Octomo MO SMS verification
OCTOMO_API_KEY=
OCTOMO_API_BASE_URL=https://api.octoverse.kr/octomo/v1
OCTOMO_RECEIVER_PHONE=1666-3538

# Google reCAPTCHA
GOOGLE_RECAPTCHA_SECRET=

# RAG sync
BENEFIT_RAG_SEED_ENABLED=true
BENEFIT_RAG_SYNC_ENABLED=true
BENEFIT_RAG_SYNC_INITIAL_DELAY_MS=300000
BENEFIT_RAG_SYNC_FIXED_DELAY_MS=3600000
BENEFIT_RAG_SYNC_DELAY_MS=0

# Frontend/OAuth redirects
OAUTH2_NEW_USER_REDIRECT_URI=http://localhost:5173/login?step=oauthIntegration&verifiedType=oauth
OAUTH2_EXIST_USER_REDIRECT_URI=http://localhost:5173/login?oauth=processing
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# Internal service-to-service imports
INTERNAL_API_KEY=change-me
